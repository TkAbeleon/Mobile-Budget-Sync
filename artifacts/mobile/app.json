{
  "expo": {
    "name": "BudgetSmart",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0F1A"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#0C0F1A",
      "package": "com.randriamanantenatsikynyantsa.mobile",
      "config": {
        "googleMaps": {
          "apiKey": "..."
        }
      },
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "a040ed70-90de-4a15-bf1a-079175adc1c3"
      }
    },
    "owner": "tsikynyantsa"
  }
}